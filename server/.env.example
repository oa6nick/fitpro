# --- FitPro server ---
PORT=4000
NODE_ENV=development
# Хост прослушивания (0.0.0.0 в проде для доступа по IP; локально 127.0.0.1)
# HTTP_HOST=127.0.0.1

# JWT (обязательно сменить в проде; в dev есть безопасный дефолт)
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=7d

# CORS origin фронта (Vite)
CLIENT_ORIGIN=http://localhost:5173
# Отдавать собранный фронт из Express (single-origin прод). В dev — false (Vite сам).
# SERVE_CLIENT=false
# secure-cookie только при HTTPS. На HTTP-по-IP оставить false.
# COOKIE_SECURE=false

# --- БД ---
# DB_DRIVER=pglite  -> встроенный Postgres в процессе (по умолчанию, бережёт ноут, без Docker)
# DB_DRIVER=pg      -> внешний PostgreSQL по DATABASE_URL (Docker/прод)
DB_DRIVER=pglite
# Путь к файловой БД PGlite (когда DB_DRIVER=pglite)
PGLITE_DATA_DIR=./.data/fitpro
# Строка подключения (когда DB_DRIVER=pg)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/fitpro

# Загрузки файлов (фото/видео/PDF)
UPLOADS_DIR=./uploads
