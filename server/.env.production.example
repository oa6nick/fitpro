# --- FitPro server (production / деплой по IP) ---
NODE_ENV=production
PORT=8080
# Слушать на всех интерфейсах, чтобы был доступ по внешнему IP
HTTP_HOST=0.0.0.0

# ОБЯЗАТЕЛЬНО сменить на длинную случайную строку:
JWT_SECRET=__сгенерировать__openssl_rand_hex_32__
JWT_EXPIRES_IN=7d

# Single-origin: Express отдаёт собранный фронт (client/dist) и API на одном порту
SERVE_CLIENT=true
# На голом HTTP по IP (без TLS) cookie НЕ должна быть secure, иначе логин слетает.
# Поставить true только когда появится домен + HTTPS.
COOKIE_SECURE=false
# Same-origin деплой — CORS не используется, но оставим для совместимости
CLIENT_ORIGIN=http://localhost:8080

# --- БД ---
# Для демо по IP достаточно встроенного PGlite (файловое хранилище, без Docker).
DB_DRIVER=pglite
PGLITE_DATA_DIR=./.data/fitpro
# Для внешнего Postgres: DB_DRIVER=pg + DATABASE_URL=postgresql://...
# DATABASE_URL=

UPLOADS_DIR=./uploads
