# --- FitPro server (production, за nginx) ---
NODE_ENV=production
# Node слушает локально, наружу смотрит только nginx (см. deploy/nginx/fitpro.conf)
PORT=3000
HTTP_HOST=127.0.0.1

# ОБЯЗАТЕЛЬНО сменить на длинную случайную строку:
JWT_SECRET=__сгенерировать__openssl_rand_hex_32__
JWT_EXPIRES_IN=7d

# Single-origin: Express отдаёт собранный фронт (client/dist) и API на одном порту
SERVE_CLIENT=true
# true только при HTTPS (домен + certbot). На голом HTTP логин слетит.
COOKIE_SECURE=false
CLIENT_ORIGIN=http://204.168.243.54
# Публичный адрес — используется в ссылках писем (инвайты, welcome).
PUBLIC_URL=http://204.168.243.54
# За nginx обязателен (X-Forwarded-* для rate-limit и secure-cookie).
TRUST_PROXY=true

# --- БД (прод — только настоящий Postgres) ---
DB_DRIVER=pg
DATABASE_URL=postgresql://fitpro:__пароль__@127.0.0.1:5432/fitpro
# PGlite оставлен только для локальной разработки:
# DB_DRIVER=pglite
# PGLITE_DATA_DIR=./.data/fitpro

# Абсолютный путь: uploads живут в shared/, переживают релизы.
UPLOADS_DIR=/opt/fitpro/shared/uploads

# --- Почта ---
# resend | smtp | off. off = письма не шлются, коды печатаются в лог.
EMAIL_PROVIDER=resend
EMAIL_FROM="FitPro <hello@oasixlab.com>"
RESEND_API_KEY=__ключ_из_resend__
# Для SMTP-провайдера (не используется при resend):
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=

# --- Web-push (VAPID) ---
# Без ключей push просто выключен (кнопка в кабинете не показывается).
# Сгенерировать: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@oasixlab.com
