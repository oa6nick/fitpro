{
  "name": "fitpro-platform",
  "version": "0.1.0",
  "private": true,
  "description": "FitPro Platform — операционная система для онлайн-тренера (MVP)",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace server && npm run build --workspace client",
    "typecheck": "npm run typecheck --workspace server && npm run typecheck --workspace client",
    "start": "npm start --workspace server",
    "prod:build": "npm run build --workspace client",
    "prod:setup": "npm run db:migrate && npm run seed",
    "test": "npm run test --workspace server",
    "db:generate": "npm run db:generate --workspace server",
    "db:migrate": "npm run db:migrate --workspace server",
    "db:studio": "npm run db:studio --workspace server",
    "seed": "npm run seed --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.30.1",
    "drizzle-orm": "^0.39.0"
  },
  "engines": {
    "node": ">=20"
  }
}
