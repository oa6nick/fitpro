{
  "$meta": {
    "source": "client/src/index.css + client/tailwind.config.js",
    "note": "Источник истины — веб. При изменении токенов в вебе обновить этот файл и нативные темы (mobile/ios Theme.swift, mobile/android ui/theme). hex предвычислены из hsl.",
    "updated": "2026-07-17"
  },
  "font": {
    "family": "Geist",
    "variable": true,
    "license": "SIL OFL 1.1 (vercel/geist-font)",
    "fallbacks": ["system-ui", "-apple-system", "Segoe UI", "Roboto", "sans-serif"]
  },
  "radius": {
    "sm": 8,
    "md": 12,
    "lg": 16,
    "control": 16,
    "panel": 20,
    "hero": 28,
    "shell": 32
  },
  "typography": {
    "note": "rem = 16px; для clamp() взято мобильное (минимальное) значение",
    "eyebrow": { "size": 11.5, "weight": 600, "letterSpacing": "0.26em", "uppercase": true },
    "caption": { "size": 11.5, "weight": 600, "letterSpacing": "0.22em", "uppercase": true },
    "display": { "size": 41.6, "weight": 500, "lineHeight": 0.98, "letterSpacing": "-0.02em" },
    "pageTitle": { "size": 25.6, "weight": 500, "lineHeight": 1.1, "letterSpacing": "-0.01em" },
    "sectionTitle": { "size": 27.2, "weight": 500, "lineHeight": 1.08, "letterSpacing": "-0.015em" }
  },
  "motion": {
    "springEasing": [0.16, 1, 0.3, 1],
    "fadeIn": { "durationMs": 400 },
    "slideUp": { "durationMs": 500, "translateY": 14 },
    "scaleIn": { "durationMs": 300, "fromScale": 0.97 }
  },
